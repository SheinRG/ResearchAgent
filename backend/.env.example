# Ollama (Local LLM)
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT=120

# Redis
REDIS_URL=redis://redis:6379/0
CACHE_TTL=3600

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://agent:agent@postgres:5432/research_agent

# Agent Settings
MAX_ITERATIONS=2
MAX_SUB_QUERIES=4
SEARCH_RESULTS_PER_QUERY=5
SCRAPE_TOP_N=3
CHUNK_SIZE=500
CHUNK_OVERLAP=50
RERANK_TOP_K=10

# Server
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
LOG_LEVEL=INFO
